# Database Configuration (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/esusu_db?sslmode=require"

# JWT Configuration
JWT_SECRET="your-secret-key-change-in-production-min-32-chars"

# Email Configuration (Resend.com — free tier)
# Sign up at https://resend.com and get an API key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Esusu Digital <onboarding@resend.dev>"

# Cloudinary (File uploads for payment proofs)
# Sign up at https://cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Application Configuration
PORT=5000
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000"

# OTP Configuration
OTP_EXPIRY_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL="debug"
